<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_color"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvDisplay"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fontFamily="sans-serif-light"
        android:gravity="bottom|end"
        android:maxLines="2"
        android:padding="10dp"
        android:text="@string/btn_0"
        android:textColor="@color/display_text"
        android:textSize="72sp" />

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="4"
        android:rowCount="5">

        <!-- Row 1 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClear"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:text="@string/btn_clear"
            android:textSize="24sp"
            app:backgroundTint="@color/btn_function"
            app:cornerRadius="20dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDelete"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:text="@string/btn_delete"
            android:textSize="24sp"
            app:backgroundTint="@color/btn_function"
            app:cornerRadius="20dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPercent"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:text="@string/btn_percent"
            android:textSize="24sp"
            app:backgroundTint="@color/btn_function"
            app:cornerRadius="20dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDivide"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:text="@string/btn_divide"
            android:textSize="28sp"
            app:backgroundTint="@color/btn_operator"
            app:cornerRadius="20dp" />

        <!-- Row 2 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn7"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:text="@string/btn_7"
            android:textSize="24sp"
            app:backgroundTint="@color/btn_number"
            app:cornerRadius="20dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn8"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:text="@string/btn_8"
            android:textSize="24sp"
            app:backgroundTint="@color/btn_number"
            app:cornerRadius="20dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn9"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:text="@string/btn_9"
            android:textSize="24sp"
            app:backgroundTint="@color/btn_number"
            app:cornerRadius="20dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMultiply"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:text="@string/btn_multiply"
            android:textSize="28sp"
            app:backgroundTint="@color/btn_operator"
            app:cornerRadius="20dp" />

        <!-- Row 3 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn4"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:text="@string/btn_4"
            android:textSize="24sp"
            app:backgroundTint="@color/btn_number"
            app:cornerRadius="20dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn5"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:text="@string/btn_5"
            android:textSize="24sp"
            app:backgroundTint="@color/btn_number"
            app:cornerRadius="20dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn6"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:text="@string/btn_6"
            android:textSize="24sp"
            app:backgroundTint="@color/btn_number"
            app:cornerRadius="20dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubtract"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:text="@string/btn_subtract"
            android:textSize="28sp"
            app:backgroundTint="@color/btn_operator"
            app:cornerRadius="20dp" />

        <!-- Row 4 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn1"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:text="@string/btn_1"
            android:textSize="24sp"
            app:backgroundTint="@color/btn_number"
            app:cornerRadius="20dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn2"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:text="@string/btn_2"
            android:textSize="24sp"
            app:backgroundTint="@color/btn_number"
            app:cornerRadius="20dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn3"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:text="@string/btn_3"
            android:textSize="24sp"
            app:backgroundTint="@color/btn_number"
            app:cornerRadius="20dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAdd"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:text="@string/btn_add"
            android:textSize="28sp"
            app:backgroundTint="@color/btn_operator"
            app:cornerRadius="20dp" />

        <!-- Row 5 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDot"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:text="@string/btn_dot"
            android:textSize="24sp"
            app:backgroundTint="@color/btn_number"
            app:cornerRadius="20dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn0"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:text="@string/btn_0"
            android:textSize="24sp"
            app:backgroundTint="@color/btn_number"
            app:cornerRadius="20dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEquals"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnSpan="2"
            android:layout_columnWeight="2"
            android:layout_margin="6dp"
            android:text="@string/btn_equals"
            android:textSize="28sp"
            app:backgroundTint="@color/btn_operator"
            app:cornerRadius="20dp" />

    </GridLayout>

</LinearLayout>